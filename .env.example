# Postgres connection — Railway's Postgres add-on injects DATABASE_URL automatically
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bilingual_books"

# Better-Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-32-random-bytes"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin account — created/updated by prisma/seed.ts on first boot
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Google Analytics (optional) — keep existing GA tag or replace
NEXT_PUBLIC_GA_ID="G-HP6ZDS0E04"

# Polite User-Agent for Gutenberg book proxy fetches (optional)
GUTENBERG_USER_AGENT="bilingual-books/1.0 (https://github.com/Lachy-Dauth/bilingual-books)"

# Resend (transactional email) — used by the password-reset flow.
# Get an API key at https://resend.com — the free tier covers 3,000/month.
# If RESEND_API_KEY is unset, reset emails are only logged (Railway logs)
# and never delivered.
RESEND_API_KEY=""
# Verified sender. For dev / first-time setup, "onboarding@resend.dev" works
# without any DNS setup but Resend will only let you send to the address you
# signed up with. For production, verify your own domain in the Resend
# dashboard and use something like "Bilingual Books <noreply@yourdomain.com>".
RESEND_FROM="Bilingual Books <onboarding@resend.dev>"
