# Postgres connection — Railway's Postgres add-on injects DATABASE_URL automatically
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bilingual_books"

# Better-Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-32-random-bytes"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin account — created/updated by prisma/seed.ts on first boot
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Google Analytics (optional) — keep existing GA tag or replace
NEXT_PUBLIC_GA_ID="G-HP6ZDS0E04"

# Polite User-Agent for Gutenberg book proxy fetches (optional)
GUTENBERG_USER_AGENT="bilingual-books/1.0 (https://github.com/Lachy-Dauth/bilingual-books)"

# Gmail API (transactional email) — used by the password-reset flow.
# We send via HTTPS to Gmail's API, not SMTP, because Railway blocks
# outbound SMTP ports.
#
# Setup (one-time):
#   1. In Google Cloud Console for your existing project (the one with
#      GOOGLE_CLIENT_ID below): APIs & Services → Library → enable "Gmail API".
#   2. APIs & Services → OAuth consent screen → Edit → add scope
#      "https://www.googleapis.com/auth/gmail.send".
#   3. APIs & Services → Credentials → your OAuth Web client →
#      Authorized redirect URIs → add http://localhost:47432/oauth/callback.
#   4. Locally: copy GOOGLE_CLIENT_ID/SECRET into .env.local, then
#      `npm run gmail:get-token`. Sign in as the sending account and
#      approve. The script prints a refresh token.
#   5. Paste it as GMAIL_REFRESH_TOKEN below (and into Railway).
#
# Without GMAIL_REFRESH_TOKEN the password-reset endpoint still works
# but the reset URL is only logged to the server (Railway logs).
GMAIL_REFRESH_TOKEN=""
# Optional. Defaults to bilingualbooksgen@gmail.com. The account that
# was signed in during the refresh-token flow.
GMAIL_SEND_FROM=""
