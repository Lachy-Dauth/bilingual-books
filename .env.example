# Postgres connection — Railway's Postgres add-on injects DATABASE_URL automatically
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bilingual_books"

# Better-Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-32-random-bytes"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin account — created/updated by prisma/seed.ts on first boot
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Google Analytics (optional) — keep existing GA tag or replace
NEXT_PUBLIC_GA_ID="G-HP6ZDS0E04"

# Polite User-Agent for Gutenberg book proxy fetches (optional)
GUTENBERG_USER_AGENT="bilingual-books/1.0 (https://github.com/Lachy-Dauth/bilingual-books)"

# SMTP credentials — used by the password-reset flow. Defaults work for
# Gmail; just set SMTP_USER and SMTP_PASS.
#
# Gmail setup:
#   1. Enable 2-Step Verification on the Google account.
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#      (label it "Bilingual Books"). Google gives you a 16-character string.
#   3. SMTP_USER = full Gmail address, SMTP_PASS = the 16-character app
#      password (no spaces).
# Limits: free Gmail is 500 outbound messages/day, plenty for password resets.
# If SMTP_USER/SMTP_PASS are unset, reset emails are only logged (Railway
# logs) and never delivered.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# Optional. Defaults to "Bilingual Books <$SMTP_USER>".
SMTP_FROM=""
